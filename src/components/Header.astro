---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import {getLangFromUrl, useTranslations} from '../i18n/utils';
import {Image} from 'astro:assets';
import logoImage from '../assets/logo.jpg';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<header>
	<nav>
		<div class="brand">
            <a href={`/${lang}/`}>
                <Image src={logoImage} alt="Aesthetic Production Logo" height={40} loading="eager" fetchpriority="high" />
            </a>
		</div>
		<div class="internal-links">
            <HeaderLink href={`/${lang}/`}>{t('nav.home')}</HeaderLink>
            <HeaderLink href={`/${lang}/productions/`}>{t('nav.productions')}</HeaderLink>
	        <HeaderLink href={`/${lang}/filmographie/`}>{t('nav.filmographie')}</HeaderLink>
            <HeaderLink href={`/${lang}/about/`}>{t('nav.about')}</HeaderLink>
            <HeaderLink href={`/${lang}/contact/`}>{t('nav.contact')}</HeaderLink>
		</div>
        <div class="controls">
			<ThemeToggle />
            <LanguageSwitcher/>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
		transition: background-color 0.2s ease-in-out;
	}
	html.dark header {
		background: #18181b;
		box-shadow: 0 2px 8px rgba(var(--black), 15%);
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
        gap: 1em;
        min-height: 70px;
	}
	.brand {
        flex: 0 1 auto;
    }

    .brand a {
        display: block;
        padding: 0;
	}

    .brand img {
        height: 40px;
        width: auto;
        border-radius: 0;
    }

    .internal-links {
        flex: 1 1 auto;
        display: flex;
        justify-content: center;
        gap: 1em;
    }

    .controls {
        flex: 0 1 auto;
        display: flex;
        gap: 0.5em;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--black));
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}

    @media (max-width: 768px) {
        /* Adjusted breakpoint */
		nav {
			flex-direction: column;
			gap: 1em;
			padding: 1em 0;
		}
		.internal-links {
            order: 1; /* Place links below brand and controls */
			flex-wrap: wrap;
			gap: 0.5em 1em;
		}
	}
</style>
