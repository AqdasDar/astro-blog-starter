---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const siteUrl = Astro.site ? Astro.site.href.replace(/\/$/, '') : 'https://aesthetic-production.fr';
const pathname = Astro.url.pathname;

let frPath = pathname;
let enPath = pathname;
if (pathname.startsWith('/en/')) {
    frPath = pathname.replace('/en/', '/fr/');
} else if (pathname.startsWith('/fr/')) {
    enPath = pathname.replace('/fr/', '/en/');
} else {
    frPath = '/fr/';
    enPath = '/en/';
}

const frUrl = new URL(frPath, siteUrl).href;
const enUrl = new URL(enPath, siteUrl).href;

const canonicalURL = new URL(pathname, siteUrl).href;
const { title, description, image } = Astro.props;

const organizationSchema = {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Aesthetic Production",
    "url": "https://aesthetic-production.fr",
    "logo": "https://aesthetic-production.fr/favicon-512x512.png",
    "sameAs": [
        "https://www.instagram.com/aesthetics_production/",
        "https://www.youtube.com/@aestheticsproductions",
        "https://www.linkedin.com/company/aesthetic-production/"
    ],
    "description": description
};
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<!-- Favicon – Google and Bing require a multiple of 48x48 px with a stable URL -->
<link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
<link rel="icon" href="/favicon.ico" sizes="48x48" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<meta name="theme-color" content="#2337ff" />
<meta name="generator" content={Astro.generator} />

<!-- Language Alternates for Bing & Search Engines -->
<link rel="alternate" hreflang="fr" href={frUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={frUrl} />

<!-- Client Router -->
<ClientRouter />

<!-- Font preloads -->
<link rel="preload" href="/fonts/atkinson-regular.woff" as="font" type="font/woff" crossorigin />
<link rel="preload" href="/fonts/atkinson-bold.woff" as="font" type="font/woff" crossorigin />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />

<!-- Structured Data (Bing / Copilot Entity Grounding) -->
<script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
{image && <meta property="og:image" content={new URL(image, Astro.url)} />}

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
{image && <meta property="twitter:image" content={new URL(image, Astro.url)} />}

<!-- Scripts -->
<script src="../scripts/scroll-animation.js"></script>

