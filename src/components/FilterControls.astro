---
import { getLangFromUrl, useTranslations } from '../i18n/utils';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const allCategories = lang === 'fr' 
    ? [
        { id: 'Court-métrage', label: 'Court-métrage' },
        { id: 'Film institutionnel', label: 'Film institutionnel' }
      ]
    : [
        { id: 'Short Film', label: 'Short Film' },
        { id: 'Corporate', label: 'Corporate' }
      ];
---
<div class="filter-controls">
    <div class="filters">
        <span>{t('filter.label')}</span>
        <button data-category="all" class="active">{t('filter.all')}</button>
        {allCategories.map(category => (
                <button data-category={category.id}>{category.label}</button>
        ))}
    </div>
    <div class="sort">
        <label for="sort-by">{t('sort.label')}</label>
        <select id="sort-by">
            <option value="date-desc">{t('sort.dateDesc')}</option>
            <option value="date-asc">{t('sort.dateAsc')}</option>
            <option value="title-asc">{t('sort.titleAsc')}</option>
        </select>
    </div>
</div>

<script>
    document.addEventListener('astro:page-load', () => {
        const controls = document.querySelector('.filter-controls');
        if (!controls) return;

        const filterButtons = controls.querySelectorAll('.filters button');
        const sortSelect = controls.querySelector('#sort-by');
        const gallery = document.querySelector('.production-gallery');
        if (!gallery) return;

        const allProductions = Array.from(gallery.querySelectorAll('li'));

        const productionsData = allProductions.map(production => ({
            element: production,
            title: production.querySelector('.title')?.textContent.toLowerCase(),
            date: new Date(production.querySelector('.date time')?.getAttribute('datetime')),
            category: production.dataset.category,
        }));

        function applyFilterAndSort() {
            const activeFilter = controls.querySelector('.filters button.active').dataset.category;
            const sortBy = sortSelect.value;

            productionsData.forEach(production => {
                const isVisible = activeFilter === 'all' || production.category === activeFilter;
                production.element.style.display = isVisible ? '' : 'none';
            });

            const sortedProductions = [...productionsData].sort((a, b) => {
                switch (sortBy) {
                    case 'date-asc':
                        return a.date - b.date;
                    case 'title-asc':
                        return a.title.localeCompare(b.title);
                    case 'date-desc':
                    default:
                        return b.date - a.date;
                }
            });

            sortedProductions.forEach(production => {
                gallery.appendChild(production.element);
            });
        }

        filterButtons.forEach(button => {
            button.addEventListener('click', () => {
                filterButtons.forEach(btn => btn.classList.remove('active'));
                button.classList.add('active');
                applyFilterAndSort();
            });
        });

        sortSelect.addEventListener('change', applyFilterAndSort);
    });
</script>

<style>
    /* Styles for the filter controls */
    .filter-controls {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        margin-bottom: 2rem;
        background-color: rgba(var(--gray-light), 0.5);
        border-radius: 8px;
    }

    html.dark .filter-controls {
        background-color: rgba(var(--gray-dark), 0.5);
    }

    .filters, .sort {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .filters button {
        padding: 0.5em 1em;
        border: 1px solid transparent;
        border-radius: 99px;
        background-color: transparent;
        color: rgb(var(--black));
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .filters button:hover {
        background-color: rgba(var(--gray), 0.2);
    }

    .filters button.active {
        background-color: var(--accent);
        color: white;
        font-weight: bold;
    }

    #sort-by {
        padding: 0.5em;
        border-radius: 4px;
        border: 1px solid #ccc;
    }
</style>
