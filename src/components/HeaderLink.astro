---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname;

// Normalize paths by removing leading and trailing slashes for precise comparison
const normalize = (path: string) => path.replace(/^\/|\/$/g, '');

const normHref = normalize(href?.toString() || '');
const normPathname = normalize(pathname);

// Active if exact match, or if it is a subpage of a section (excluding root lang folder matching other pages)
const isActive = normHref === normPathname || (
    normHref !== 'fr' && normHref !== 'en' && normHref !== '' && 
    normPathname.startsWith(normHref + '/')
);
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: 600;
	}
</style>
