---
import type {CollectionEntry} from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import {Image} from 'astro:assets';

import { getLangFromUrl } from '../i18n/utils';

type Props = CollectionEntry<'productions'>['data'];

const {title, description, releaseDate, updatedDate, heroImage, videoUrl} = Astro.props;
const lang = getLangFromUrl(Astro.url);
---

<html lang={lang}>
<head>
    <BaseHead title={title} description={description} image={heroImage}/>
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Movie",
        "name": title,
        "description": description,
        "datePublished": releaseDate.toISOString(),
        "director": {
            "@type": "Person",
            "name": "Hamza Dar"
        },
        ...(heroImage && {"image": new URL(heroImage, Astro.site).href}),
        ...(videoUrl && {"embedUrl": videoUrl})
    })}/>
    <style>
        main {
            width: calc(100% - 2em);
            max-width: 100%;
            margin: 0;
        }

        .media-container {
            width: 100%;
            margin-bottom: 2rem;
        }

        .media-container img {
            display: block;
            margin: 0 auto;
            border-radius: 12px;
            box-shadow: var(--box-shadow);
        }

        .video-responsive {
            overflow: hidden;
            padding-bottom: 56.25%;
            position: relative;
            height: 0;
            border-radius: 12px;
            box-shadow: var(--box-shadow);
        }

        .video-responsive iframe {
            left: 0;
            top: 0;
            height: 100%;
            width: 100%;
            position: absolute;
        }

        .prose {
            max-width: 720px;
            margin: auto;
            padding: 1em;
            color: rgb(var(--gray-dark));
        }

        html.dark .prose {
            color: rgb(var(--gray-dark));
        }

        .title {
            margin-bottom: 1em;
            padding: 1em 0;
            text-align: center;
            line-height: 1;
        }

        .title h1 {
            margin: 0 0 0.5em 0;
        }

        .date {
            margin-bottom: 0.5em;
            color: rgb(var(--gray));
        }

        .last-updated-on {
            font-style: italic;
        }
    </style>
    <title></title>
</head>

<body>
<Header/>
<main>
    <article>
        <div class="media-container">
            {videoUrl ? (
                    <div class="video-responsive">
                        <iframe
                                src={videoUrl}
                                title="Embedded video"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen
                        ></iframe>
                    </div>
            ) : (
                heroImage &&
                <Image src={heroImage} widths={[400, 800, 1200]} sizes="100vw" alt={`Affiche pour ${title}`}/>
            )}
        </div>
        <div class="prose">
            <div class="title">
                <div class="date">
                    <FormattedDate date={releaseDate}/>
                    {
                        updatedDate && (
                                    <div class="last-updated-on">
                                        Mis à jour le
                                        <FormattedDate date={updatedDate}/>
                                    </div>
                        )
                    }
                </div>
                <h1>{title}</h1>
                <hr/>
            </div>
            <slot/>
        </div>
    </article>
</main>
<Footer/>
</body>
</html>
