---
// src/pages/en/cv.astro
import PageLayout from '../../layouts/PageLayout.astro';

const screenplayDirecting = [
    { year: 2026, title: 'Au fil du temps', role: 'Documentaire (en cours de production)' },
    { year: 2025, title: 'Trèfle de vie', role: 'short film' },
    { year: 2024, title: 'Une chance pour réussir', role: 'short film' },
    { year: 2023, title: 'Albedo', role: 'short film' },
];

const acting = [
    { year: 2025, title: 'Trèfle de vie', role: 'short film', details: 'Lead role - produced by Aesthetic Production' },
    { year: 2022, title: 'Echecs & Maths', role: 'short film', details: 'Role of Seikou - produced by IamDESI' },
];

const productionAssistant = [
    { year: 2026, title: 'Vérifions', role: 'Laurence Boccolini' },
    { year: 2025, title: 'Les Rois du Panier', role: 'Cristina Cordula' },
    { year: 2025, title: 'Match Aller', role: 'Inès Banzet-Benhagouga' },
    { year: 2025, title: 'Chair adolescent', role: 'Pablo Cabel' },
];


---

<PageLayout
        title="Filmographie"
        description="Discover the filmography of Aesthetic Production."
>
    <style>
        .filmographie-section {
            margin-bottom: 3rem;
        }

        .filmographie-section h2 {
            border-bottom: 2px solid rgb(var(--accent));
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
            font-size: 1.8rem;
        }

        .filmographie-grid {
            display: grid;
            grid-template-columns: 100px 1fr;
            gap: 0.5rem 1rem;
        }

        .filmographie-grid .year {
            font-weight: bold;
            color: rgb(var(--gray));
        }

        .filmographie-grid .details {
            font-size: 0.9rem;
            color: rgb(var(--gray));
            margin-top: 0.2rem;
        }

        .download-button {
            display: inline-block;
            padding: 0.75rem 1.5rem;
            border: 1px solid rgb(var(--accent));
            background-color: transparent;
            color: rgb(var(--accent));
            border-radius: 4px;
            text-decoration: none;
            transition: background-color 0.2s ease, color 0.2s ease;
        }

        .download-button:hover {
            background-color: rgb(var(--accent));
            color: white;
        }
    </style>

    <div class="filmographie-section">
        <h2>Scénariste - Réalisation</h2>
        <div class="filmographie-grid">
            {screenplayDirecting.map(item => (
                <div class="year">{item.year}</div>
                <div><strong>{item.title}</strong> - <em>{item.role}</em></div>
            ))}
        </div>
    </div>

    <div class="filmographie-section">
        <h2>Comédien</h2>
        <div class="filmographie-grid">
            {acting.map(item => (
                <div class="year">{item.year}</div>
                <div>
                    <strong>{item.title}</strong> - <em>{item.role}</em>
                    {item.details && <div class="details">{item.details}</div>}
                </div>
            ))}
        </div>
    </div>

    <div class="filmographie-section">
        <h2>Assistant de Production</h2>
        <div class="filmographie-grid">
            {productionAssistant.map(item => (
                <div class="year">{item.year}</div>
                <div><strong>{item.title}</strong> - <em>{item.role}</em></div>
            ))}
        </div>
    </div>

</PageLayout>
