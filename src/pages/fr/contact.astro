---
import PageLayout from '../../layouts/PageLayout.astro';
import {Image} from 'astro:assets';
import instagramQr from '../../assets/instagram-qr.png';
---
<PageLayout
        title="Contact"
        description="Contactez Aesthetic Production pour toute collaboration, question ou demande de devis."
>
    <style>
        .contact-intro {
            margin-bottom: 2rem;
        }

        .contact-form {
            margin-top: 2rem;
        }

        .form-group {
            margin-bottom: 1rem;
        }

        .form-group label {
            display: block;
            margin-bottom: 0.5rem;
        }

        .form-group input,
        .form-group textarea {
            width: 100%;
            padding: 0.5rem;
            border: 1px solid #ccc;
            border-radius: 4px;
            background-color: white;
            color: rgb(var(--black));
        }

        html.dark .form-group input,
        html.dark .form-group textarea {
            background-color: rgb(var(--gray-light));
            border-color: #555;
            color: rgb(var(--black));
        }

        .submit-button {
            padding: 0.75rem 1.5rem;
            border: none;
            background-color: rgb(var(--accent));
            color: white;
            border-radius: 4px;
            cursor: pointer;
        }

        .contact-details {
            margin-top: 3rem;
        }

        .qr-container {
            margin-top: 2rem;
            text-align: left;
        }

        .qr-code {
            max-width: 200px;
            height: auto;
            border-radius: 8px;
            border: 1px solid #ddd;
            margin-top: 0.5rem;
        }

        html.dark .qr-code {
            border-color: #444;
        }
    </style>

    <p class="contact-intro">
        Notre équipe est à votre disposition pour étudier toute opportunité de collaboration et échanger sur vos projets
        créatifs. N'hésitez pas à nous contacter via le formulaire ci-dessous ou directement par email.
    </p>

    <form class="contact-form">
        <div class="form-group">
            <label for="name">Nom</label>
            <input type="text" id="name" name="name" required/>
        </div>
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required/>
        </div>
        <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="5" required></textarea>
        </div>
        <button type="submit" class="submit-button">Envoyer</button>
        <div id="form-status" style="margin-top: 1rem; font-weight: bold; display: none;"></div>
    </form>

    <script>
        const form = document.querySelector('.contact-form') as HTMLFormElement;
        const statusDiv = document.getElementById('form-status') as HTMLDivElement;
        const submitBtn = form.querySelector('.submit-button') as HTMLButtonElement;

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.textContent = 'Envoi en cours...';
            statusDiv.style.display = 'none';

            const formData = new FormData(form);
            try {
                const response = await fetch('/contact-submit.php', {
                    method: 'POST',
                    body: formData
                });
                const message = await response.text();
                statusDiv.style.display = 'block';
                if (response.ok) {
                    statusDiv.style.color = '#2e7d32'; // vert
                    statusDiv.textContent = message;
                    form.reset();
                } else {
                    statusDiv.style.color = '#d32f2f'; // rouge
                    statusDiv.textContent = message || "Une erreur est survenue.";
                }
            } catch (err) {
                statusDiv.style.display = 'block';
                statusDiv.style.color = '#d32f2f';
                statusDiv.textContent = "Impossible d'envoyer le message. Veuillez vérifier votre connexion.";
            } finally {
                submitBtn.disabled = false;
                submitBtn.textContent = 'Envoyer';
            }
        });
    </script>

    <h3 class="contact-details">Coordonnées</h3>
    <p>
        <strong>Email:</strong> <a href="mailto:contact@aesthetic-production.fr">contact@aesthetic-production.fr</a>
    </p>
    <p>
        <strong>Réseaux Sociaux:</strong> Suivez-nous sur <a href="https://www.instagram.com/aesthetics_production/" target="_blank">Instagram</a> et <a href="https://www.youtube.com/@aestheticsproductions" target="_blank">YouTube</a>.
    </p>

    <div class="qr-container">
        <strong>Code QR Instagram:</strong><br/>
        <Image src={instagramQr} alt="Code QR Instagram" class="qr-code" />
    </div>
</PageLayout>
