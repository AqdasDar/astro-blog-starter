---
import {type CollectionEntry, getCollection} from 'astro:content';
import ProductionPost from '../../../layouts/ProductionPost.astro';
import {render} from 'astro:content';

export async function getStaticPaths() {
    const productions = await getCollection('productions');
    return productions
        .filter((production) => production.id.startsWith('fr/'))
        .map((production) => ({
            params: {slug: production.id.replace(/^fr\//, '')},
            props: production,
        }));
}
type Props = CollectionEntry<'productions'>;

const production = Astro.props;
const {Content} = await render(production);
---

<ProductionPost {...production.data}>
    <Content/>
</ProductionPost>
